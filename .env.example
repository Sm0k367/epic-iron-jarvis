# Epic Tech AI — environment template
# Copy to .env (gitignored) or set in your shell / OS secret store.
# NEVER commit real API keys. NEVER hardcode secrets in source.

# --- Optional shared state home (one brain across projects) ---
# EPIC_HOME=C:\Users\You\.epic-tech
# IRONJARVIS_HOME=C:\Users\You\.ironjarvis

# --- Daemon auth when exposing beyond localhost ---
# IRONJARVIS_TOKEN=generate-a-long-random-token

# --- LLM providers (prefer Dashboard → Connections / Secrets vault) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# PIXIO_API_KEY=

# --- Local model ---
# OLLAMA_HOST=http://127.0.0.1:11434

# --- Telegram bot (or store telegram bot token in Secrets vault) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ALLOWED_SENDERS=

# --- Stripe (billing). Keys ONLY here or in the encrypted vault — never in git. ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_CREDITS_100=
# STRIPE_PRICE_CREDITS_500=
# STRIPE_PRICE_CREDITS_2000=

# --- Optional ---
# IRONJARVIS_MAX_UPLOAD_MB=100
# IRONJARVIS_AUTO_BACKUP=on
